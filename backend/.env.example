# Общий файл окружения для монорепозитория backend.
# Скопируйте в backend/.env и подставьте свои значения.
# Сервисы лежат в backend/apps/{access-service,scenario-service,device-service}.

# --- access-service ---
ACCESS_CONTROL_DB_URL="postgresql://access_control_service:access_control_service@localhost:5432/access_control_service?schema=public"
ACCESS_CONTROL_SERVICE_PORT=8085

# --- scenario-service (MongoDB) ---
# Если Mongo запущен через `infrastructure/docker-compose.yml`, то там включена авторизация:
# user=device_service password=password (authSource=admin)
SCENARIO_DATABASE_URL="mongodb://device_service:password@localhost:27017/scenario?authSource=admin"
SCENARIO_SERVICE_PORT=3001
# docker-compose ports (host -> container)
MONGODB_PORT=27017
KEYCLOAK_PORT=8080
OLLAMA_PORT=11434
# Socket.IO /zigbee: разрешённые Origin (через запятую); иначе http://localhost:3000
# SCENARIO_CORS_ORIGINS=http://localhost:3000,https://app.example.com
# MQTT-конфигурация Zigbee теперь хранится в MongoDB (коллекция house_mqtt_configs)
# и управляется через API: PUT /zigbee/house-mqtt/:houseId

# --- device-service (NestJS + Prisma, PostgreSQL) ---
DEVICE_SERVICE_DATABASE_URL="postgresql://devices:devices@localhost:5432/devices?schema=public"
DEVICE_SERVICE_PORT=3000
# URL сервиса устройств (используется scenario-service для синхронизации каталога)
DEVICE_SERVICE_URL="http://localhost:8090"

# --- Central MQTT broker (EMQX) ---
# Используется scenario-service для подписки на телеметрию и публикации команд.
# Запущен через `infrastructure/docker-compose.yml` сервис mqtt-gateway.
CENTRAL_MQTT_URL=mqtt://localhost:1883
CENTRAL_MQTT_USERNAME=
CENTRAL_MQTT_PASSWORD=

# --- Ollama (локальный LLM) ---
# Локальная разработка (вне Docker):
OLLAMA_URL="http://localhost:11434"
# Запуск через docker-compose (scenario-service внутри compose-сети):
# OLLAMA_URL="http://ollama:11434"
# Модель (должна быть предзагружена через `ollama pull` или сервисом ollama-pull)
OLLAMA_MODEL="qwen2.5:3b"
