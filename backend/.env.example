# Общий файл окружения для монорепозитория backend.
# Скопируйте в backend/.env и подставьте свои значения.
# Сервисы лежат в backend/apps/{access-service,scenario-service,device-service}.

# --- access-service ---
ACCESS_CONTROL_DB_URL="postgresql://access_control_service:access_control_service@localhost:5432/access_control_service?schema=public"
ACCESS_CONTROL_SERVICE_PORT=8085

# --- scenario-service (MongoDB) ---
SCENARIO_DATABASE_URL="mongodb://localhost:27017/scenario"
SCENARIO_SERVICE_PORT=3001
# Socket.IO /zigbee: разрешённые Origin (через запятую); иначе http://localhost:3000
# SCENARIO_CORS_ORIGINS=http://localhost:3000,https://app.example.com
# zigbee2mqtt (MQTT): если ZIGBEE_MQTT_URL пустой — клиент не стартует
ZIGBEE_MQTT_URL="mqtt://192.168.1.10:1883"
# ZIGBEE_MQTT_TOPIC_PREFIX="zigbee2mqtt"
# ZIGBEE_MQTT_USERNAME=
# ZIGBEE_MQTT_PASSWORD=
# после подписки запросить bridge/devices (true по умолчанию; false / 0 / off — отключить)
# ZIGBEE_MQTT_REQUEST_DEVICES_ON_CONNECT=true
# лимит символов тела сообщения в логе (по умолчанию 16000)
# ZIGBEE_MQTT_LOG_MAX_CHARS=16000

# --- device-service (NestJS + Prisma, PostgreSQL) ---
DEVICE_SERVICE_DATABASE_URL="postgresql://devices:devices@localhost:5432/devices?schema=public"
DEVICE_SERVICE_PORT=3000
# URL сервиса устройств (используется scenario-service для синхронизации каталога)
DEVICE_SERVICE_URL="http://localhost:8090"
