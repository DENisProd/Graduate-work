{
  "name": "graduate-work-backend",
  "private": true,
  "devDependencies": {
    "tsc-alias": "^1.8.16"
  },
  "scripts": {
    "postinstall": "pnpm run prisma:generate",
    "prisma:generate": "pnpm --filter access-control-service exec prisma generate && pnpm --filter device-service exec prisma generate",
    "build": "pnpm -r run build",
    "build:access": "pnpm --filter access-control-service run build",
    "build:scenario": "pnpm --filter scenario-service run build",
    "build:devices": "pnpm --filter device-service run build",
    "dev:access": "pnpm --filter access-control-service run start:dev",
    "dev:scenario": "pnpm --filter scenario-service run start:dev",
    "dev:devices": "pnpm --filter device-service run start:dev",
    "lint:scenario": "pnpm --filter scenario-service run lint"
  }
}
