generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

////////////////////////////////////////////////////////////
// ENUMS
////////////////////////////////////////////////////////////

enum AccessRightType {
  ALLOW
  DENY
  READ
  WRITE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

enum ResourceType {
  HOUSE
  ROOM
  DEVICE
  DEVICE_FUNCTION
  SCENE
  GROUP
  AUTOMATION
}

enum HousePermission {
  INVITE_MEMBERS
  EDIT_ROLES
  MANAGE_DEVICES
  MANAGE_AUTOMATIONS
}

enum PolicySubjectType {
  USER
  ROLE
  MEMBER
  ANYONE
}

enum PermissionSourceType {
  ROLE
  DIRECT
  POLICY
}

enum ConflictResolutionStrategy {
  DENY_OVERRIDES
  ALLOW_OVERRIDES
  PRIORITY
}

////////////////////////////////////////////////////////////
// USERS
////////////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  externalUserId String  @unique @map("external_user_id")
  avatarUrl      String? @map("avatar_url")
  /** Имя для UI (Keycloak / клиент), синхронизируется заголовком X-User-Display-Name */
  displayName    String? @map("display_name") @db.VarChar(255)

  memberships   HouseMember[]
  ownedHouses   House[]       @relation("HouseOwner")
  grantedRights AccessRight[] @relation("GrantedBy")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("access_users")
}

////////////////////////////////////////////////////////////
// HOUSE
////////////////////////////////////////////////////////////

model House {
  id        String  @id @default(uuid())
  name      String  @db.VarChar(255)
  avatarUrl String? @map("avatar_url")
  address   String? @db.VarChar(500)

  conflictStrategy ConflictResolutionStrategy @default(DENY_OVERRIDES)

  ownerId String? @map("owner_id")
  owner   User?   @relation("HouseOwner", fields: [ownerId], references: [id])

  members     HouseMember[]
  roles       HouseRole[]
  resources   Resource[]
  invitations HouseInvitation[]
  policies    AccessPolicy[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("access_houses")
}

////////////////////////////////////////////////////////////
// MEMBERSHIP
////////////////////////////////////////////////////////////

model HouseMember {
  id String @id @default(uuid())

  houseId String @map("house_id")
  house   House  @relation(fields: [houseId], references: [id])
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])

  roles                HouseMemberRole[]
  directRights         AccessRight[]
  effectivePermissions EffectivePermission[]
  invitationsSent      HouseInvitation[]

  joinedAt  DateTime  @default(now()) @map("joined_at")
  removedAt DateTime? @map("removed_at")

  @@unique([houseId, userId])
  @@index([userId])
  @@index([houseId])
  @@map("access_house_members")
}

////////////////////////////////////////////////////////////
// ROLES
////////////////////////////////////////////////////////////

model HouseRole {
  id       String  @id @default(uuid())
  name     String  @db.VarChar(100)
  priority Int
  isSystem Boolean @default(false) @map("is_system")

  houseId String @map("house_id")
  house   House  @relation(fields: [houseId], references: [id])

  members      HouseMemberRole[]
  permissions  HouseRolePermission[]
  accessRights AccessRight[]
  invitations  HouseInvitation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([houseId, priority])
  @@map("access_house_roles")
}

model HouseMemberRole {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now()) @map("assigned_at")

  houseMemberId String      @map("house_member_id")
  houseMember   HouseMember @relation(fields: [houseMemberId], references: [id])
  roleId        String      @map("role_id")
  role          HouseRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([houseMemberId, roleId])
  @@map("access_house_member_roles")
}

model HouseRolePermission {
  id         String          @id @default(uuid())
  permission HousePermission

  roleId String    @map("role_id")
  role   HouseRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("access_house_role_permissions")
}

////////////////////////////////////////////////////////////
// RESOURCES (hierarchy)
////////////////////////////////////////////////////////////

model Resource {
  id         String       @id @default(uuid())
  type       ResourceType
  name       String?      @map("name")
  externalId String?      @map("external_id")
  path       String       @db.VarChar(500)
  depth      Int

  houseId  String    @map("house_id")
  house    House     @relation(fields: [houseId], references: [id])
  parentId String?   @map("parent_id")
  parent   Resource? @relation("ResourceHierarchy", fields: [parentId], references: [id])

  children             Resource[]            @relation("ResourceHierarchy")
  accessRights         AccessRight[]
  policies             AccessPolicy[]
  effectivePermissions EffectivePermission[]

  metadata Json? @map("metadata")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([houseId])
  @@index([parentId])
  @@index([path])
  @@map("access_resources")
}

////////////////////////////////////////////////////////////
// ACCESS RIGHTS (RBAC)
////////////////////////////////////////////////////////////

model AccessRight {
  id              String          @id @default(uuid())
  accessRightType AccessRightType @map("access_right_type")
  parameters      Json?

  resourceId    String       @map("resource_id")
  resource      Resource     @relation(fields: [resourceId], references: [id])
  houseMemberId String?      @map("house_member_id")
  houseMember   HouseMember? @relation(fields: [houseMemberId], references: [id])
  roleId        String?      @map("role_id")
  role          HouseRole?   @relation(fields: [roleId], references: [id])
  grantedById   String?      @map("granted_by_id")
  grantedBy     User?        @relation("GrantedBy", fields: [grantedById], references: [id])

  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([resourceId])
  @@index([houseMemberId])
  @@index([roleId])
  @@map("access_rights")
}

////////////////////////////////////////////////////////////
// POLICIES (ABAC)
////////////////////////////////////////////////////////////

model AccessPolicy {
  id          String            @id @default(uuid())
  name        String
  effect      AccessRightType
  subjectType PolicySubjectType
  subjectId   String?
  condition   Json?
  priority    Int               @default(100)

  houseId    String    @map("house_id")
  house      House     @relation(fields: [houseId], references: [id])
  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([houseId])
  @@index([resourceId])
  @@map("access_policies")
}

////////////////////////////////////////////////////////////
// EFFECTIVE PERMISSIONS CACHE
////////////////////////////////////////////////////////////

model EffectivePermission {
  id              String               @id @default(uuid())
  accessRightType AccessRightType
  sourceType      PermissionSourceType
  sourceId        String?

  houseMemberId String      @map("house_member_id")
  member        HouseMember @relation(fields: [houseMemberId], references: [id])
  resourceId    String      @map("resource_id")
  resource      Resource    @relation(fields: [resourceId], references: [id])

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([houseMemberId, resourceId, accessRightType])
  @@index([houseMemberId])
  @@index([resourceId])
  @@map("access_effective_permissions")
}

////////////////////////////////////////////////////////////
// INVITATIONS
////////////////////////////////////////////////////////////

model HouseInvitation {
  id                 String            @id @default(uuid())
  note               String?           @db.VarChar(255)
  tokenHash          String            @unique @map("token_hash")
  /// Явный набор доменных прав (HousePermission); используется, если roleId не задан
  invitedPermissions HousePermission[] @default([]) @map("invited_permissions")
  status             InvitationStatus  @default(PENDING)

  houseId     String       @map("house_id")
  house       House        @relation(fields: [houseId], references: [id])
  roleId      String?      @map("role_id")
  role        HouseRole?   @relation(fields: [roleId], references: [id])
  invitedById String?      @map("invited_by_id")
  invitedBy   HouseMember? @relation(fields: [invitedById], references: [id])

  createdAt  DateTime  @default(now()) @map("created_at")
  acceptedAt DateTime? @map("accepted_at")
  expiresAt  DateTime? @map("expires_at")

  @@index([houseId])
  @@map("access_house_invitations")
}

////////////////////////////////////////////////////////////
// DEVICE AUTH SESSIONS
////////////////////////////////////////////////////////////

model DeviceAuthSession {
  id             String    @id @default(uuid())
  userCode       String    @unique @map("user_code")
  callbackUrl    String?   @map("callback_url")
  status         String    @default("pending")
  authCode       String?   @map("auth_code")
  externalUserId String?   @map("external_user_id")
  displayName    String?   @map("display_name")
  authorizedAt   DateTime? @map("authorized_at")
  lastPolledAt   DateTime? @map("last_polled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime  @map("expires_at")

  @@index([externalUserId])
  @@map("device_auth_sessions")
}

////////////////////////////////////////////////////////////
// AUDIT LOG
////////////////////////////////////////////////////////////

model AccessAuditLog {
  id         String  @id @default(uuid())
  actorId    String  @map("actor_id")
  action     String
  resourceId String? @map("resource_id")
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([resourceId])
  @@map("access_audit_logs")
}

////////////////////////////////////////////////////////////
// DEVICE CATALOG
////////////////////////////////////////////////////////////

enum DeviceStatus {
  ONLINE
  OFFLINE
}

enum DeviceFunctionType {
  READ
  WRITE
  READ_WRITE
}

enum ActionType {
  TOGGLE
  COMMAND
  VALUE
}

model DeviceType {
  id           Int                    @id @default(autoincrement())
  code         String                 @unique @db.VarChar(50)
  active       Boolean                @default(true)
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  categories   DeviceCategory[]
  translations DeviceTypeTranslation[]

  @@map("device_types")
}

model DeviceCategory {
  id           Int                        @id @default(autoincrement())
  code         String                     @unique @db.VarChar(50)
  deviceTypeId Int                        @map("device_type_id")
  deviceType   DeviceType                 @relation(fields: [deviceTypeId], references: [id])
  active       Boolean                    @default(true)
  isModerated  Boolean                    @default(true) @map("is_moderated")
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  devices      Device[]
  translations DeviceCategoryTranslation[]

  @@map("device_categories")
}

model Device {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  deviceCategoryId Int                @map("device_category_id")
  deviceCategory   DeviceCategory     @relation(fields: [deviceCategoryId], references: [id])
  status           DeviceStatus       @default(OFFLINE)
  serialNumber     String?            @db.VarChar(100) @map("serial_number")
  firmwareVersion  String?            @db.VarChar(50) @map("firmware_version")
  active           Boolean            @default(true)
  isModerated      Boolean            @default(true) @map("is_moderated")
  lastSeenAt       DateTime?          @map("last_seen_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  translations     DeviceTranslation[]
  functions        DeviceFunction[]

  @@map("devices")
}

model DeviceFunction {
  id           Int                       @id @default(autoincrement())
  code         String                    @db.VarChar(50)
  deviceId     Int                       @map("device_id")
  device       Device                    @relation(fields: [deviceId], references: [id])
  functionType DeviceFunctionType        @map("function_type")
  currentValue String?                   @map("current_value")
  minValue     Float?                    @map("min_value")
  maxValue     Float?                    @map("max_value")
  unit         String?                   @db.VarChar(50)
  active       Boolean                   @default(true)
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  translations DeviceFunctionTranslation[]
  actions      DeviceFunctionAction[]

  @@unique([deviceId, code])
  @@map("device_functions")
}

model DeviceFunctionAction {
  id               Int                             @id @default(autoincrement())
  code             String                          @db.VarChar(50)
  deviceFunctionId Int                             @map("device_function_id")
  deviceFunction   DeviceFunction                  @relation(fields: [deviceFunctionId], references: [id])
  actionType       ActionType                      @map("action_type")
  payloadTemplate  String?                         @map("payload_template")
  active           Boolean                         @default(true)
  createdAt        DateTime                        @default(now()) @map("created_at")
  updatedAt        DateTime                        @updatedAt @map("updated_at")
  translations     DeviceFunctionActionTranslation[]

  @@unique([deviceFunctionId, code])
  @@map("device_function_actions")
}

model DeviceTranslation {
  id       Int    @id @default(autoincrement())
  locale   String @db.VarChar(10)
  name     String
  description String?
  deviceId Int    @map("device_id")
  device   Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, locale])
  @@map("device_translations")
}

model DeviceCategoryTranslation {
  id               Int            @id @default(autoincrement())
  locale           String         @db.VarChar(10)
  name             String
  description      String?
  deviceCategoryId Int            @map("device_category_id")
  deviceCategory   DeviceCategory @relation(fields: [deviceCategoryId], references: [id])

  @@unique([deviceCategoryId, locale])
  @@map("device_category_translations")
}

model DeviceTypeTranslation {
  id           Int        @id @default(autoincrement())
  locale       String     @db.VarChar(10)
  name         String
  description  String?
  deviceTypeId Int        @map("device_type_id")
  deviceType   DeviceType @relation(fields: [deviceTypeId], references: [id])

  @@unique([deviceTypeId, locale])
  @@map("device_type_translations")
}

model DeviceFunctionTranslation {
  id               Int            @id @default(autoincrement())
  locale           String         @db.VarChar(10)
  name             String
  description      String?
  deviceFunctionId Int            @map("device_function_id")
  deviceFunction   DeviceFunction @relation(fields: [deviceFunctionId], references: [id])

  @@unique([deviceFunctionId, locale])
  @@map("device_function_translations")
}

model DeviceFunctionActionTranslation {
  id                   Int                  @id @default(autoincrement())
  locale               String               @db.VarChar(10)
  name                 String
  description          String?
  deviceFunctionActionId Int                @map("device_function_action_id")
  deviceFunctionAction DeviceFunctionAction @relation(fields: [deviceFunctionActionId], references: [id])

  @@unique([deviceFunctionActionId, locale])
  @@map("device_function_action_translations")
}
