# API Gateway configuration
GATEWAY_PORT=8080

# Upstream services
ACCESS_SERVICE_URL=http://localhost:8085
DEVICE_SERVICE_URL=http://localhost:3000
SCENARIO_SERVICE_URL=http://localhost:3001

# Keycloak JWT validation
# Same issuer as AUTH_KEYCLOAK_ISSUER in frontend (.env)
# e.g. http://localhost:8080/realms/master
KEYCLOAK_ISSUER=http://localhost:8080/realms/master

# CORS — comma-separated list of allowed origins
# GATEWAY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
