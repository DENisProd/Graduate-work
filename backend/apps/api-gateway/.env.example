# API Gateway configuration
GATEWAY_PORT=8050

# Upstream services
ACCESS_SERVICE_URL=http://localhost:8086
GATEWAY_DEVICE_URL=http://localhost:8090
SCENARIO_SERVICE_URL=http://localhost:8095

# Keycloak JWT validation
# Same issuer as AUTH_KEYCLOAK_ISSUER in frontend (.env)
# e.g. http://localhost:8080/realms/smart-home (see infrastructure/keycloak/realm-export.json)
KEYCLOAK_ISSUER=http://localhost:8080/realms/smart-home

# CORS — comma-separated list of allowed origins
# GATEWAY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MQTT broker — WebSocket URL, proxied at /api/mqtt
MQTT_BROKER_URL=ws://localhost:18083
