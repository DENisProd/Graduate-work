SPRING_PROFILES_ACTIVE=dev

# Postgres Root
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Keycloak
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak_pass
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true

# Service DB Credentials
HOME_DB_URL=jdbc:postgresql://localhost:5432/home_service
HOME_DB_USERNAME=home_service
HOME_DB_PASSWORD=home_service

DEVICE_DB_NAME=device_service
DEVICE_DB_USERNAME=postgres
DEVICE_DB_PASSWORD=password

ROOM_DB_URL=jdbc:postgresql://localhost:5432/room_service
ROOM_DB_USERNAME=room_service
ROOM_DB_PASSWORD=room_service

USER_PROFILE_DB_URL=jdbc:postgresql://postgres:5432/user_profile_service
USER_PROFILE_DB_USERNAME=user_profile_service
USER_PROFILE_DB_PASSWORD=user_profile_service

ACCESS_CONTROL_DB_USERNAME=access_control_service
ACCESS_CONTROL_DB_PASSWORD=access_control_service
# ACCESS_CONTROL_DB_URL="postgresql://postgres:password@localhost:5432/access_control_service?schema=public"
ACCESS_CONTROL_DB_URL="postgresql://bk:bk@127.0.0.1:5432/acs"
# ACCESS_CONTROL_SHADOW_DB_URL="postgresql://postgres:password@localhost:5432/access_control_service?schema=public"

# Service Ports
HOME_SERVICE_PORT=8081
DEVICE_SERVICE_PORT=8082
SCENARIO_SERVICE_PORT=8083
USER_PROFILE_SERVICE_PORT=8084
ACCESS_CONTROL_SERVICE_PORT=8085
GATEWAY_SERVICE_PORT=8080

# Scenario Service
