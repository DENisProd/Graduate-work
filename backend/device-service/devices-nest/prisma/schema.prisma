generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DeviceType {
  id          Int                    @id @default(autoincrement())
  code        String                 @unique @db.VarChar(50)
  active      Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  categories  DeviceCategory[]
  translations DeviceTypeTranslation[]
}

model DeviceCategory {
  id          Int                       @id @default(autoincrement())
  code        String                    @unique @db.VarChar(50)
  deviceType  DeviceType                @relation(fields: [deviceTypeId], references: [id])
  deviceTypeId Int
  active      Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  devices     Device[]
  translations DeviceCategoryTranslation[]
}

model Device {
  id             Int                  @id @default(autoincrement())
  code           String               @unique @db.VarChar(100)
  deviceCategory DeviceCategory       @relation(fields: [deviceCategoryId], references: [id])
  deviceCategoryId Int
  status         DeviceStatus         @default(OFFLINE)
  serialNumber   String?              @db.VarChar(100)
  firmwareVersion String?             @db.VarChar(50)
  active         Boolean              @default(true)
  lastSeenAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  translations   DeviceTranslation[]
  functions      DeviceFunction[]
}

model DeviceFunction {
  id           Int                     @id @default(autoincrement())
  code         String                  @db.VarChar(50)
  device       Device                  @relation(fields: [deviceId], references: [id])
  deviceId     Int
  functionType DeviceFunctionType
  currentValue String?
  minValue     Float?
  maxValue     Float?
  unit         String?                 @db.VarChar(50)
  active       Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations DeviceFunctionTranslation[]
  actions      DeviceFunctionAction[]

  @@unique([deviceId, code])
}

model DeviceFunctionAction {
  id              Int                            @id @default(autoincrement())
  code            String                         @db.VarChar(50)
  deviceFunction  DeviceFunction                 @relation(fields: [deviceFunctionId], references: [id])
  deviceFunctionId Int
  actionType      ActionType
  payloadTemplate String?
  active          Boolean                        @default(true)
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  translations    DeviceFunctionActionTranslation[]

  @@unique([deviceFunctionId, code])
}

model DeviceTranslation {
  id          Int       @id @default(autoincrement())
  locale      String    @db.VarChar(10)
  name        String
  description String?
  device      Device    @relation(fields: [deviceId], references: [id])
  deviceId    Int

  @@unique([deviceId, locale])
}

model DeviceCategoryTranslation {
  id             Int           @id @default(autoincrement())
  locale         String        @db.VarChar(10)
  name           String
  description    String?
  deviceCategory DeviceCategory @relation(fields: [deviceCategoryId], references: [id])
  deviceCategoryId Int

  @@unique([deviceCategoryId, locale])
}

model DeviceTypeTranslation {
  id          Int        @id @default(autoincrement())
  locale      String     @db.VarChar(10)
  name        String
  description String?
  deviceType  DeviceType @relation(fields: [deviceTypeId], references: [id])
  deviceTypeId Int

  @@unique([deviceTypeId, locale])
}

model DeviceFunctionTranslation {
  id             Int            @id @default(autoincrement())
  locale         String         @db.VarChar(10)
  name           String
  description    String?
  deviceFunction DeviceFunction @relation(fields: [deviceFunctionId], references: [id])
  deviceFunctionId Int

  @@unique([deviceFunctionId, locale])
}

model DeviceFunctionActionTranslation {
  id                   Int                   @id @default(autoincrement())
  locale               String                @db.VarChar(10)
  name                 String
  description          String?
  deviceFunctionAction DeviceFunctionAction  @relation(fields: [deviceFunctionActionId], references: [id])
  deviceFunctionActionId Int

  @@unique([deviceFunctionActionId, locale])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
}

enum DeviceFunctionType {
  READ
  WRITE
  READ_WRITE
}

enum ActionType {
  TOGGLE
  COMMAND
  VALUE
}

