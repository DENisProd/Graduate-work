# EMQX credential bootstrap — copy to credentials.env and fill in values.
# This file is intentionally NOT included in docker-compose env_file entries;
# use it as a reference when provisioning accounts via the EMQX Dashboard or
# REST API after the first boot.
#
# NEVER commit credentials.env to version control.

# Dashboard admin password (set via EMQX_DASHBOARD__DEFAULT_PASSWORD in docker-compose,
# then rotate through the Dashboard after first login).
EMQX_ADMIN_PASSWORD=changeme

# MQTT client credentials for scenario-service.
# Задайте в infrastructure/.env — mqtt-bootstrap создаст пользователя и ACL автоматически.
# То же значение пароля укажите в корневом .env как CENTRAL_MQTT_PASSWORD.
SCENARIO_SERVICE_MQTT_USERNAME=scenario-service
SCENARIO_SERVICE_MQTT_PASSWORD=change-me-scenario-mqtt

# MQTT client credentials for each local-server instance (one per house).
# Create per-house accounts with a naming convention, e.g. local-server-{houseId}.
# LOCAL_SERVER_MQTT_USERNAME=local-server-<houseId>
# LOCAL_SERVER_MQTT_PASSWORD=
