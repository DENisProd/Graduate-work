# Copy to infrastructure/.env before: docker compose up -d
# SCENARIO_SERVICE_MQTT_PASSWORD must match CENTRAL_MQTT_PASSWORD in root .env

# Keycloak public URL — MUST match AUTH_KEYCLOAK_ISSUER in root .env (without /realms/...).
# Local:  KEYCLOAK_PUBLIC_URL=http://localhost:8080
# Prod:   KEYCLOAK_PUBLIC_URL=https://auth-home.darksecrets.ru
#         KC_PROXY=edge   (TLS terminates at reverse proxy)
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_PASSWORD=admin

EMQX_DASHBOARD_PASSWORD=changeme
SCENARIO_SERVICE_MQTT_USERNAME=scenario-service
SCENARIO_SERVICE_MQTT_PASSWORD=change-me-scenario-mqtt
