:80 {
    # Cloud api-gateway: access + scenario (must be before /api/* → local-backend)
    handle /api/access/* {
        reverse_proxy {$ACCESS_GATEWAY_UPSTREAM:host.docker.internal:8050}
    }
    handle /api/scenario/* {
        reverse_proxy {$ACCESS_GATEWAY_UPSTREAM:host.docker.internal:8050}
    }

    # Proxy API + WebSocket to local-backend
    handle /api/* {
        reverse_proxy local-backend:8080
    }

    # WebSocket (Socket.IO) upgrade path
    handle /socket.io/* {
        reverse_proxy local-backend:8080
    }

    # Serve built frontend (SPA — fallback to index.html)
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    encode gzip
}
