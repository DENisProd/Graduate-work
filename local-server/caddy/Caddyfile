:80 {
    # Proxy API + WebSocket to local-backend
    handle /api/* {
        reverse_proxy local-backend:8080
    }

    # WebSocket (Socket.IO) upgrade path
    handle /socket.io/* {
        reverse_proxy local-backend:8080
    }

    # Serve built frontend (SPA — fallback to index.html)
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    encode gzip
}
