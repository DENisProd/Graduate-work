## local-server environment overrides
##
## Notes:
## - All values are optional; `config/default.toml` provides defaults.
## - You can also create `config/local.toml` (gitignored) for per-machine overrides.

# HTTP port to bind (default: 8080)
LOCAL_SERVER_PORT=8080

# SQLite URL (default: sqlite:./data/local.db)
DATABASE_URL=sqlite:./data/local.db

# Optional: enable MQTT ingestion (e.g. Zigbee2MQTT broker)
# ZIGBEE_MQTT_URL=mqtt://localhost:1883

# Optional: override Zigbee2MQTT topic prefix (default: zigbee2mqtt)
# MQTT_TOPIC_PREFIX=zigbee2mqtt

# Optional: access-service URL for cloud device-authorization flow
# ACCESS_SERVICE_URL=http://localhost:8085

# Optional: externally reachable URL of this local-server for callback mode
# LOCAL_SERVER_PUBLIC_URL=https://your-tunnel.example

# Optional: CORS allowlist for browser clients (comma-separated)
# LOCAL_SERVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
