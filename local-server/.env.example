# ── local-backend ────────────────────────────────────────────────────────────
# Pre-built ARM64 image from GHCR (CI) or local test image:
# LOCAL_BACKEND_IMAGE=ghcr.io/denisprod/graduate-work/local-backend:latest
# LOCAL_BACKEND_IMAGE=local-backend:test
LOCAL_SERVER_SERIAL=00:00:00:00:00:00
SYNC_INTERVAL_SECS=300
# Host port for direct API access (8080 is used by Zigbee2MQTT web UI)
LOCAL_SERVER_PORT=8081
# Local Mosquitto in docker-compose — do NOT use cloud gateway /api/mqtt for ingest
ZIGBEE_MQTT_URL=mqtt://mosquitto:1883

# ── USB device paths (Linux) ─────────────────────────────────────────────────
ZIGBEE_DEVICE=/dev/ttyACM0
MODBUS_DEVICE=/dev/ttyUSB0

# ── Modbus settings ──────────────────────────────────────────────────────────
BAUD_RATE=9600
MODBUS_TIMEOUT_MS=1000

# ── Caddy ────────────────────────────────────────────────────────────────────
CADDY_HTTP_PORT=80

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
