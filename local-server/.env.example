# Copy to .env and adjust for your machine.

# ── local-backend ────────────────────────────────────────────────────────────
LOCAL_SERVER_SERIAL=00:00:00:00:00:00
SYNC_INTERVAL_SECS=300
# Host port for direct API access (optional; UI uses Caddy on :80 by default)
LOCAL_SERVER_PORT=8080

# ── USB device paths (Linux) ─────────────────────────────────────────────────
ZIGBEE_DEVICE=/dev/ttyACM0
MODBUS_DEVICE=/dev/ttyUSB0

# ── Modbus settings ──────────────────────────────────────────────────────────
BAUD_RATE=9600
MODBUS_TIMEOUT_MS=1000

# Host port for api-gateway / access-service proxy target (runs on the host, not in compose)
ACCESS_GATEWAY_UPSTREAM=host.docker.internal:8050

# ── local-backend cloud sync (Orange Pi → dev PC with gateway) ───────────────
# IP of the machine running pnpm gateway:dev + access + scenario services
# ACCESS_SERVICE_URL=http://192.168.0.150:8050
# CLOUD_SYNC_API_URL=http://192.168.0.150:8050
# SCENARIO_SERVICE_URL=http://192.168.0.150:8050/api/scenario

# ── Caddy ────────────────────────────────────────────────────────────────────
# Change if port 80 is already taken on the host
CADDY_HTTP_PORT=80

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
