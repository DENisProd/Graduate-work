# URL of the local Rust server (Raspberry Pi or localhost)
# Change in Settings page at runtime — no restart needed
VITE_LOCAL_SERVER_URL=http://localhost:8080

# NestJS access-service (houses, members, roles). Not the same as local-server.
VITE_ACCESS_SERVICE_URL=http://localhost:8085

# Default MQTT gateway URL (can be changed in Settings at runtime)
VITE_DEFAULT_GATEWAY_URL=mqtt://localhost:1883

# Default user UUID for X-User-Id header (no Keycloak here)
VITE_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000
