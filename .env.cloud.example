# Cloud deployment environment variables.
# Copy this file to .env and fill in secrets before running docker compose.
#
# Usage:
#   cp .env.cloud.example .env
#   docker compose build
#   docker compose up -d

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# DB users created by infrastructure/postgres/init-databases.sh
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
ACCESS_CONTROL_DB_USERNAME=access_control_service
ACCESS_CONTROL_DB_PASSWORD=access_control_service
DEVICE_DB_USERNAME=devices
DEVICE_DB_PASSWORD=devices
HOME_DB_USERNAME=home_service
HOME_DB_PASSWORD=home_service
ROOM_DB_USERNAME=room_service
ROOM_DB_PASSWORD=room_service
USER_PROFILE_DB_USERNAME=user_profile
USER_PROFILE_DB_PASSWORD=user_profile

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USERNAME=device_service
MONGO_PASSWORD=password

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080

# ── MQTT (EMQX) ───────────────────────────────────────────────────────────────
EMQX_DASHBOARD_PASSWORD=changeme
EMQX_NODE__COOKIE=smart-home-dev-cookie-change-me
MQTT_GATEWAY_TCP_PORT=1883
MQTT_GATEWAY_WS_PORT=8083
MQTT_GATEWAY_DASHBOARD_PORT=18083
# Optional: set if EMQX requires auth
CENTRAL_MQTT_URL=mqtt://mqtt-gateway:1883
CENTRAL_MQTT_USERNAME=
CENTRAL_MQTT_PASSWORD=

# ── access-service ────────────────────────────────────────────────────────────
ACCESS_SERVICE_PORT=8086
# URL that the browser sees for device authentication confirmation
DEVICE_AUTH_VERIFICATION_URL=http://localhost:3000/device-auth
ACCESS_CORS_ORIGINS=http://localhost:3000,http://localhost:8082

# ── scenario-service ──────────────────────────────────────────────────────────
SCENARIO_SERVICE_PORT=3001
SCENARIO_CORS_ORIGINS=http://localhost:3000,http://localhost:8082

# ── api-gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8082
GATEWAY_CORS_ORIGINS=http://localhost:3000
# Must match the Keycloak realm issuer URL reachable from inside the gateway container
KEYCLOAK_ISSUER=http://keycloak:8080/realms/smart-home

# ── frontend (Next.js) ────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=changeme
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=smart-home-frontend
AUTH_KEYCLOAK_SECRET=
# Must be reachable from the user's browser (for OAuth redirects)
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/smart-home

# NEXT_PUBLIC_* are baked into the JS bundle at build time.
# Set these to URLs reachable from the user's browser.
NEXT_PUBLIC_API_URL=http://localhost:8082
NEXT_PUBLIC_ACCESS_API_URL=http://localhost:8086
NEXT_PUBLIC_PHYSICAL_DEVICES_API_URL=http://localhost:3001
NEXT_PUBLIC_USE_MOCKS=false
