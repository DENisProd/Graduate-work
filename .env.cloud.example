# =============================================================================
# Облачный деплой Smart Home
# =============================================================================
#
#   cp .env.cloud.example .env
#   docker compose up -d --build
#
# Этот файл читает docker compose из КОРНЯ репозитория.
# Для разработки без Docker см. backend/.env.example
#
# =============================================================================

# -----------------------------------------------------------------------------
# 1. ОБЯЗАТЕЛЬНО ЗАПОЛНИТЬ
# -----------------------------------------------------------------------------
# AUTH_SECRET — секрет сессий NextAuth. Сгенерировать: npx auth secret
#
# AUTH_KEYCLOAK_SECRET — после первого запуска:
#   1. http://localhost:8080 → admin / см. KEYCLOAK_ADMIN_PASSWORD ниже
#   2. Clients → smart-home-frontend → Credentials → Client secret
#   3. Вставить сюда и пересобрать: docker compose up -d --build frontend

AUTH_SECRET=
AUTH_KEYCLOAK_ID=smart-home-frontend
AUTH_KEYCLOAK_SECRET=

# -----------------------------------------------------------------------------
# 2. URL ДЛЯ БРАУЗЕРА (localhost = локальный облачный стенд)
# -----------------------------------------------------------------------------
# Адреса, которые открывает пользователь в браузере.
# NEXT_PUBLIC_GATEWAY_URL вшивается в frontend при СБОРКЕ — после смены нужен rebuild.
# Для продакшена укажите публичный URL api-gateway (тот же, что открывает браузер).

AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/smart-home

NEXT_PUBLIC_GATEWAY_URL=http://localhost:8082
# Внутри Docker-сети (server-side health check в контейнере frontend)
GATEWAY_INTERNAL_URL=http://api-gateway:8082

# -----------------------------------------------------------------------------
# 3. ПАРОЛИ ИНФРАСТРУКТУРЫ
# -----------------------------------------------------------------------------
# postgres, mongodb, keycloak, mqtt-gateway (см. infrastructure/docker-compose.yml)

POSTGRES_PASSWORD=postgres

# Пользователь БД access-service (тот же логин/пароль в URL ниже → access-service)
ACCESS_CONTROL_DB_USERNAME=access_control_service
ACCESS_CONTROL_DB_PASSWORD=access_control_service

MONGO_USERNAME=device_service
MONGO_PASSWORD=password

KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
# Публичный hostname Keycloak для OAuth (localhost или ваш домен)
KEYCLOAK_PUBLIC_URL=http://localhost:8080

EMQX_DASHBOARD_PASSWORD=changeme

# -----------------------------------------------------------------------------
# 4. ПРИЛОЖЕНИЯ — порты и CORS (обычно менять не нужно)
# -----------------------------------------------------------------------------
# access-service, scenario-service, api-gateway, frontend (docker-compose.yml)

ACCESS_SERVICE_PORT=8086
SCENARIO_SERVICE_PORT=3001
GATEWAY_PORT=8082

DEVICE_AUTH_VERIFICATION_URL=http://localhost:3000/device-auth
ACCESS_CORS_ORIGINS=http://localhost:3000,http://localhost:8082
SCENARIO_CORS_ORIGINS=http://localhost:3000,http://localhost:8082
GATEWAY_CORS_ORIGINS=http://localhost:3000

# JWT-проверка внутри Docker-сети (hostname контейнера keycloak, не localhost)
KEYCLOAK_ISSUER=http://keycloak:8080/realms/smart-home

# api-gateway → WebSocket EMQX (внутри Docker-сети; с хоста dashboard на :8083)
MQTT_BROKER_URL=ws://mqtt-gateway:8083

# scenario-service → MQTT-брокер mqtt-gateway
CENTRAL_MQTT_URL=mqtt://mqtt-gateway:1883
CENTRAL_MQTT_USERNAME=
CENTRAL_MQTT_PASSWORD=

# Порты EMQX на хосте (dashboard: http://localhost:18083, login admin / EMQX_DASHBOARD_PASSWORD)
MQTT_GATEWAY_TCP_PORT=1883
MQTT_GATEWAY_DASHBOARD_PORT=18083
AUTH_SECRET=fhsfgs7fg8sf8s
AUTH_KEYCLOAK_ID=smart-home-frontend
AUTH_KEYCLOAK_SECRET=f8s7f8sf8sf8s